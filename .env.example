# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=transactions
FRAUD_ALERTS_TOPIC=fraud_alerts

# Producer
TX_PER_SECOND=5
FRAUD_PROBABILITY=0.08
RANDOM_SEED=42

# Fraud rules
HIGH_VALUE_THRESHOLD=5000
IMPOSSIBLE_TRAVEL_WINDOW_MINUTES=10
WATERMARK_DELAY=15 minutes

# Spark
SPARK_APP_NAME=fraud-detection
SPARK_CHECKPOINT_ROOT=/tmp/spark-checkpoints

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=frauddb
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=fraud_pass

# Airflow
AIRFLOW_UID=50000
AIRFLOW_POSTGRES_CONN_ID=postgres_default
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
REPORTS_DIR=/opt/airflow/reports
